<h1>My tasks</h1>
<ul>
  <% @tasks.each do |task|%>
  <li><%= link_to task.title, task_path(task)%>
  <%= link_to "Delete", task_path(task),
  data: {turbo_method: :delete, turbo_confirm: "Do you want to delete this task?"}%>
  </li>
  <% end %>
</ul>

<h4><%= link_to "Add a new task", new_task_path%></h4>
