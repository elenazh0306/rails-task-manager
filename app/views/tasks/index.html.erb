<div class="w-75 mx-auto my-5 p-3">
  <h1>My tasks</h1>
  <ul class="list-group">
    <% @tasks.each do |task|%>
    <li class="list-group-item"><%= check_box_tag "completed", "1", task.completed, disabled: true %><%= link_to task.title, task_path(task)%>
    <%= link_to edit_task_path(task) do%>
      <i class="fa-solid fa-pen-to-square"></i>
    <% end %>
    <%= link_to task_path(task), data: {turbo_method: :delete, turbo_confirm: "Do you want to delete this task?"} do%>
      <i class='fa-solid fa-trash'></i>
    <% end %>
    </li>
    <% end %>
  </ul>

  <p class="p-4"><i class="fa-solid fa-plus"></i><%= link_to "Add a new task", new_task_path%></p>
</div>
